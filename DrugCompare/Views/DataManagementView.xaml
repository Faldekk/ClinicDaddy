<UserControl x:Class="DrugCompare.Views.DataManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="White"
            CornerRadius="12"
            Padding="14"
            BorderBrush="#D6DEE8"
            BorderThickness="1"
            Margin="0,12,0,0">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Data Management"
                               FontSize="18"
                               FontWeight="Bold"/>

                    <TextBlock Text="Imported dataset versions and source tracking."
                               FontSize="12"
                               Foreground="#607080"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Reload data status"
                        Command="{Binding LoadDataManagementCommand}"
                        Width="160"
                        Height="34"/>
            </Grid>

            <Grid Grid.Row="1"
                  Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#F8FAFC"
                        BorderBrush="#D6DEE8"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14"
                        Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="EMA Import"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="{Binding EmaImportSummary}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Foreground="#1B2A38"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Background="#FFF7E6"
                        BorderBrush="#F2C879"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14"
                        Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="DDInter Import"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="{Binding DdinterImportSummary}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Foreground="#1B2A38"/>
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Grid.Row="2"
                       Text="Recent imports"
                       FontSize="15"
                       FontWeight="Bold"
                       Margin="0,0,0,8"/>

            <DataGrid Grid.Row="3"
                      ItemsSource="{Binding RecentDataImports}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      FontSize="12">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Source"
                                        Binding="{Binding SourceName}"
                                        Width="100"/>

                    <DataGridTextColumn Header="File"
                                        Binding="{Binding FileName}"
                                        Width="260"/>

                    <DataGridTextColumn Header="Imported At"
                                        Binding="{Binding ImportedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                        Width="150"/>

                    <DataGridTextColumn Header="Records"
                                        Binding="{Binding RecordsImported, StringFormat=N0}"
                                        Width="110"/>

                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding ImportStatus}"
                                        Width="120"/>

                    <DataGridTextColumn Header="Notes"
                                        Binding="{Binding Notes}"
                                        Width="350"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>