<Window x:Class="DrugCompare.Features.ChPLNavigator.RawChplTextWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Surowy tekst z PDF"
        Height="760"
        Width="1100"
        MinHeight="560"
        MinWidth="850"
        WindowStartupLocation="CenterOwner"
        Background="#F3F4F6">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="12"
                Padding="16"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Margin="0,0,0,12">

            <StackPanel>
                <TextBlock Text="Surowy tekst z PDF"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#111827"/>

                <TextBlock Text="Podgląd tekstu odczytanego bezpośrednio z dokumentu PDF. Ten widok służy do diagnostyki parsera sekcji ChPL."
                           FontSize="13"
                           Foreground="#6B7280"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <TextBox x:Name="RawTextBox"
                 Grid.Row="1"
                 FontFamily="Consolas"
                 FontSize="13"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 IsReadOnly="True"
                 BorderBrush="#E5E7EB"
                 BorderThickness="1"
                 Padding="12"
                 Background="White"/>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">

            <Button Content="Kopiuj całość"
                    Width="120"
                    Height="34"
                    Margin="0,0,8,0"
                    Click="CopyAll_Click"/>

            <Button Content="Zamknij"
                    Width="100"
                    Height="34"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>