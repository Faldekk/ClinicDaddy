<UserControl x:Class="DrugCompare.Features.ChPLNavigator.ChPLNavigatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#F3F4F6"
          Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="12"
                Padding="18"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Margin="0,0,0,12">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="ChPL Navigator"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#111827"
                               Margin="0,0,0,4"/>

                    <TextBlock Text="Wybierz plik PDF ChPL. System odczyta tekst, podzieli dokument na sekcje i pozwoli zapisać wynik jako JSON lub CSV."
                               FontSize="14"
                               Foreground="#6B7280"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="20,0,0,0">

                    <Button Content="Wybierz PDF"
                            Command="{Binding SelectPdfCommand}"
                            Height="36"
                            MinWidth="110"
                            Margin="0,0,8,0"
                            FontWeight="SemiBold"/>

                    <Button Content="Przetwórz ponownie"
                            Command="{Binding ExtractAndParseCommand}"
                            Height="36"
                            MinWidth="135"
                            Margin="0,0,8,0"/>

                    <Button Content="Wyczyść"
                            Command="{Binding ClearCommand}"
                            Height="36"
                            MinWidth="90"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status / selected file -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="14"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Margin="0,0,0,12">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">

                    <TextBlock Text="Wybrany plik"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#111827"/>

                    <TextBlock Text="{Binding SelectedPdfPath, TargetNullValue=Nie wybrano pliku PDF.}"
                               FontSize="13"
                               Foreground="#6B7280"
                               TextWrapping="Wrap"
                               Margin="0,3,0,8"/>

                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="13"
                               Foreground="#2563EB"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="20,0,0,0">

                    <Button Content="Surowy tekst"
                            Command="{Binding OpenRawTextWindowCommand}"
                            Height="34"
                            MinWidth="105"
                            Margin="0,0,8,0"/>

                    <Button Content="Eksport JSON"
                            Command="{Binding ExportJsonCommand}"
                            Height="34"
                            MinWidth="105"
                            Margin="0,0,8,0"/>

                    <Button Content="Eksport CSV"
                            Command="{Binding ExportCsvCommand}"
                            Height="34"
                            MinWidth="105"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="430"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sections list -->
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="12"
                    Padding="16"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    Margin="0,0,12,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Margin="0,0,0,12">

                        <TextBlock Text="Wykryte sekcje"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"/>

                        <TextBlock Text="Kliknij sekcję, aby zobaczyć jej treść po prawej stronie."
                                   FontSize="12"
                                   Foreground="#6B7280"
                                   TextWrapping="Wrap"
                                   Margin="0,3,0,0"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Sections}"
                              SelectedItem="{Binding SelectedSection}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderBrush="#E5E7EB"
                              BorderThickness="1"
                              RowHeight="38">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Sekcja"
                                                Binding="{Binding SectionNumber}"
                                                Width="70"/>

                            <DataGridTextColumn Header="Tytuł"
                                                Binding="{Binding Title}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Status"
                                                Binding="{Binding ReviewStatus}"
                                                Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Section Preview -->
            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="12"
                    Padding="18"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#EEF2FF"
                            CornerRadius="10"
                            Padding="14"
                            BorderBrush="#C7D2FE"
                            BorderThickness="1"
                            Margin="0,0,0,12">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{Binding SelectedSection.SectionNumber, TargetNullValue=—}"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="#2563EB"
                                       Margin="0,0,16,0"
                                       VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding SelectedSection.Title, TargetNullValue=Wybierz sekcję z listy}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="#111827"
                                           TextWrapping="Wrap"/>

                                <TextBlock Text="{Binding SelectedSection.TagsText}"
                                           FontSize="13"
                                           Foreground="#6B7280"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Background="#F9FAFB"
                            CornerRadius="8"
                            Padding="10"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            Margin="0,0,0,12">

                        <TextBlock Text="Podgląd podzielonej treści ChPL. Surowy tekst PDF jest dostępny w osobnym oknie."
                                   FontSize="13"
                                   Foreground="#374151"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <TextBox Grid.Row="2"
                             Text="{Binding SelectedSection.Text}"
                             FontFamily="Segoe UI"
                             FontSize="15"
                        
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"
                             IsReadOnly="True"
                             BorderBrush="#E5E7EB"
                             BorderThickness="1"
                             Padding="14"
                             Background="#FFFFFF"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>